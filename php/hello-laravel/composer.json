{
  "name": "partiri/hello-laravel",
  "description": "Minimal Laravel app for Partiri",
  "type": "project",
  "require": {
    "php": "^8.3",
    "laravel/framework": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
